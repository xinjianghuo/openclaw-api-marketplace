# API Marketplace 环境变量示例
# 复制为 .env.local 并填入真实值

# JWT 签名密钥 (随机生成32位hex)
JWT_SECRET=your_jwt_secret_here

# Vercel KV (可选，用于持久化许可证状态)
# 在 Vercel Dashboard → Storage → KV 创建后获取
VERCEL_KV_REST_API_URL=https://your-kv.vercel.app
VERCEL_KV_REST_API_TOKEN=your_kv_api_token

# Gumroad Webhook Secret
# 在 Gumroad → Settings → Webhooks 设置后获取
GUMROUD_WEBHOOK_SECRET=your_webhook_secret_here
